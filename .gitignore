.env
.env.local
.env.*.local
*.pem
*.key
backend/secrets/
service-account*.json
firebase-adminsdk*.json
gcloud-key*.json

# ──────────────────────────────────────────────
#  Python / Backend
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.ipynb_checkpoints/

# ──────────────────────────────────────────────
#  Flutter / Dart / Mobile
# ──────────────────────────────────────────────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/
mobile/android/.gradle/
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/
mobile/android/local.properties
mobile/android/key.properties
mobile/android/app/upload-keystore.jks
mobile/ios/Pods/
