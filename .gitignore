# ──────────────────────────────────────────────
#  Terraform / Infra
# ──────────────────────────────────────────────
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/**/*.tfvars
!infra/**/*.tfvars.example
