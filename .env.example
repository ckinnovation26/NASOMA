# ════════════════════════════════════════════════════════════
#  Nasoma — Variables d'environnement (exemple)
#  Copier en `.env` et remplir avec les vraies valeurs
#  NE JAMAIS COMMITER `.env` (cf. .gitignore)
# ════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────
APP_ENV=dev                                   # dev | staging | prod
APP_NAME=nasoma-backend
APP_VERSION=0.1.0
LOG_LEVEL=INFO                                # DEBUG | INFO | WARNING | ERROR

# ─── Backend / API ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── PostgreSQL (Cloud SQL en prod, Docker en dev) ─────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nasoma
POSTGRES_USER=nasoma
POSTGRES_PASSWORD=changeme_local_only
DATABASE_URL=postgresql+asyncpg://nasoma:changeme_local_only@localhost:5432/nasoma

# ─── Firestore (emulator en dev) ───────────────────────────
FIRESTORE_PROJECT_ID=nasoma-dev
FIRESTORE_EMULATOR_HOST=localhost:8080         # vide en prod
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Google Cloud ──────────────────────────────────────────
GCP_PROJECT_ID=nasoma-dev
GCP_REGION=africa-south1
GCP_STORAGE_BUCKET=nasoma-dev-scans
GCP_TASKS_QUEUE=ocr-queue

# ─── Firebase ──────────────────────────────────────────────
FIREBASE_PROJECT_ID=nasoma-dev
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=nasoma-dev.firebaseapp.com

# ─── IA — Google Cloud Vision ──────────────────────────────
VISION_API_ENABLED=true
VISION_API_DAILY_BUDGET_USD=10                 # kill-switch

# ─── IA — Gemini ───────────────────────────────────────────
GEMINI_API_KEY=                                # AIzaSy...
GEMINI_MODEL_EXTRACT=gemini-2.0-flash          # vision OCR fallback
GEMINI_MODEL_GENERATE=gemini-1.5-flash-8b      # extraction + exos
GEMINI_TEMPERATURE_EXTRACT=0.0
GEMINI_TEMPERATURE_GENERATE=0.2
GEMINI_DAILY_BUDGET_USD=5

# ─── JWT / Sécurité (RS256 — clés asymétriques) ────────────
# Générer en dev:
#   openssl genrsa -out secrets/jwt_private.pem 4096
#   openssl rsa -in secrets/jwt_private.pem -pubout -out secrets/jwt_public.pem
# En prod: Cloud Secret Manager + Cloud KMS, rotation tous les 90 jours
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_KEY_ID=v1                                  # incrémenter à chaque rotation
JWT_ACCESS_TOKEN_TTL_MINUTES=1440              # 24h (cf. §26 BP)
JWT_REFRESH_TOKEN_TTL_DAYS=30
JWT_OTP_LENGTH=6
JWT_OTP_TTL_MINUTES=5
JWT_OTP_MAX_ATTEMPTS=3

# ─── SMS — UNIQUEMENT POUR OTP AUTH ────────────────────────
# IMPORTANT (décision 2026-05-20):
#   • Pas de SMS rapport, pas de SMS notification.
#   • SMS utilisé UNIQUEMENT pour OTP à l'inscription/login.
#   • Tout autre canal = push FCM + in-app (gratuit).
# Économie Y2 50k users : ~4 000 $/mois.
SMS_PROVIDER=firebase                          # firebase (Phone Auth) | africastalking | twilio
AFRICASTALKING_USERNAME=sandbox                # fallback OTP only
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=NASOMA
TWILIO_ACCOUNT_SID=                            # fallback OTP only
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Paiement ──────────────────────────────────────────────
HOLLO_API_KEY=
HOLLO_MERCHANT_ID=
HOLLO_WEBHOOK_SECRET=
PAYMENT_TICKET_HMAC_SECRET=changeme_for_recharge_codes

# ─── Quotas & anti-abus ────────────────────────────────────
QUOTA_FREE_TRIAL_SCANS=3                      # plan Découverte (3 scans / 7 jours)
QUOTA_FREE_TRIAL_TTL_DAYS=7                   # expiration de la période découverte
QUOTA_THROTTLE_SCANS_PER_HOUR=20
QUOTA_PHASH_CACHE_TTL_HOURS=24
QUOTA_MAX_UPLOAD_SIZE_KB=200
QUOTA_GRACE_PERIOD_DAYS=30                    # lecture seule après expiration crédit
QUOTA_FROZEN_TO_ARCHIVED_DAYS=365             # archivage cold storage

# ─── Fallback "Always Give Value" ───────────────────────────
FALLBACK_MAX_PER_24H=1                        # anti-abus images aléatoires
FALLBACK_CONFIDENCE_THRESHOLD=0.55            # OCR confidence < ce seuil → exos depuis profil
FALLBACK_DEFAULT_EXERCISES_COUNT=3
FALLBACK_RESCAN_GRACE_MINUTES=5               # re-scan gratuit dans les 5 min

# ─── Observabilité ─────────────────────────────────────────
SENTRY_DSN=                                   # vide = Crashlytics only
BIGQUERY_DATASET=nasoma_analytics
ENABLE_AI_COST_TRACKING=true

# ─── Mobile (Flutter) ──────────────────────────────────────
# Ces variables sont injectées via --dart-define au build
# Exemples :
#   flutter run --dart-define=API_BASE_URL=https://api.nasoma.app
